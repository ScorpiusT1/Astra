<UserControl x:Class="Astra.Plugins.DataImport.Views.FileImportNodePropertyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Astra.Plugins.DataImport.Views"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             MinWidth="520">

    <UserControl.Resources>
        <ResourceDictionary>
           
        <!-- ===== 局部卡片 Border 样式（依赖主题 Brush DynamicResource） ===== -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                      Opacity="0.06"
                                      BlurRadius="18"
                                      ShadowDepth="3"
                                      Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Section 标题 ===== -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <!-- ===== 字段标签 ===== -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== 输入框 ===== -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource ThirdlyRegionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Primary 按钮 ===== -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ReverseTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DarkPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 移除图标按钮 ===== -->
        <Style x:Key="RemoveBtn" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="移除此文件" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Width="26"
                                Height="26">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource LightDangerBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 链接式小按钮（全选/全不选） ===== -->
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DarkPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 转换器实例 ===== -->
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisInv" />
        <local:CountToVisibilityConverter x:Key="CountToVis" />

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="2,0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- ════════════════════════════════════════ 文件配置 ════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource SectionCard}">
            <StackPanel>

                <!-- 标题行 -->
                <DockPanel Margin="0,0,0,14">
                    <Border DockPanel.Dock="Left"
                            Width="4"
                            CornerRadius="2"
                            Background="{DynamicResource PrimaryBrush}"
                            Margin="0,1,10,1" />
                    <TextBlock Style="{StaticResource SectionTitle}"
                               Text="文件配置" />
                </DockPanel>

                <!-- 虚拟设备别名 -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource FieldLabel}"
                               Text="虚拟设备别名" />
                    <TextBox Grid.Column="1"
                             Style="{StaticResource InputBox}"
                             Text="{Binding VirtualDeviceAlias, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="下游节点通过此别名引用本导入设备；留空则使用系统默认名称" />
                </Grid>

                <!-- 导入文件列表标签 -->
                <TextBlock Style="{StaticResource FieldLabel}"
                           Text="导入文件"
                           Margin="0,0,0,8" />

                <!-- 空文件提示 -->
                <Border Visibility="{Binding FilePaths.Count, Converter={StaticResource CountToVis}}"
                        Background="{DynamicResource ThirdlyRegionBrush}"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,8">
                    <TextBlock Text="尚未添加任何文件"
                               FontSize="12"
                               Foreground="{DynamicResource ThirdlyTextBrush}"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- 文件条目列表（最多显示 4 行，超出后可纵向滚动） -->
                <ScrollViewer MaxHeight="140"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,8">
                <ItemsControl ItemsSource="{Binding FilePaths}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ThirdlyRegionBrush}"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 文件类型图标（用颜色小圆点区分 TDMS / WAV） -->
                                    <Border Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Background="{DynamicResource PrimaryBrush}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0" />

                                    <!-- 文件路径 -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding}"
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding}" />

                                    <!-- 移除按钮 -->
                                    <Button Grid.Column="2"
                                            Style="{StaticResource RemoveBtn}"
                                            Content="✕"
                                            Tag="{Binding}"
                                            Click="OnRemoveFileClick"
                                            Margin="8,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>

                <!-- 添加文件按钮 -->
                <Button Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Left"
                        Content="＋  添加文件"
                        Click="OnAddFilesClick" />

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════ 基础配置（与 Node.IncludeInTestReport 一致） ════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource SectionCard}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <Border DockPanel.Dock="Left"
                            Width="4"
                            CornerRadius="2"
                            Background="{DynamicResource PrimaryBrush}"
                            Margin="0,1,10,1" />
                    <TextBlock Style="{StaticResource SectionTitle}"
                               Text="基础配置" />
                </DockPanel>
                <CheckBox IsChecked="{Binding IncludeInTestReport, Mode=TwoWay}"
                          Content="纳入测试报告"
                          FontSize="13"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Cursor="Hand"
                          ToolTip="关闭后该节点结果不出现在测试报告（图表与单值/曲线判定）；归档原始数据仍可按策略导出。" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════ 通道选择 ════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource SectionCard}">
            <StackPanel>

                <!-- 标题行 + 全选/全不选快捷按钮 -->
                <DockPanel Margin="0,0,0,10">
                    <Border DockPanel.Dock="Left"
                            Width="4"
                            CornerRadius="2"
                            Background="{DynamicResource InfoBrush}"
                            Margin="0,1,10,1" />
                    <TextBlock Style="{StaticResource SectionTitle}"
                               Text="通道选择"
                               VerticalAlignment="Center" />
                    <!-- 全选 / 全不选（仅有通道时可见） -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Visibility="{Binding HasChannels, Converter={StaticResource BoolToVis}}">
                        <Button Content="全选"
                                Style="{StaticResource LinkBtn}"
                                Click="OnSelectAllClick" />
                        <TextBlock Text=" / "
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThirdlyTextBrush}" />
                        <Button Content="全不选"
                                Style="{StaticResource LinkBtn}"
                                Click="OnDeselectAllClick" />
                    </StackPanel>
                </DockPanel>

                <!-- 无通道时的提示 -->
                <TextBlock Text="暂无通道，请先添加有效的数据文件"
                           FontSize="12"
                           Foreground="{DynamicResource ThirdlyTextBrush}"
                           Visibility="{Binding HasChannels, Converter={StaticResource BoolToVisInv}}" />

                <!-- 通道 CheckBox 列表（最高 4 行，超出后可纵向滚动） -->
                <ScrollViewer MaxHeight="112"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasChannels, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ChannelItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Content="{Binding DisplayName}"
                                          Margin="0,0,16,6"
                                          FontSize="12"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Cursor="Hand" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="不勾选任何通道 = 传递全部通道"
                           FontSize="11"
                           Foreground="{DynamicResource ThirdlyTextBrush}"
                           Margin="0,6,0,0"
                           Visibility="{Binding HasChannels, Converter={StaticResource BoolToVis}}" />

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════ 波形预览 ════════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource SectionCard}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"  />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <Border DockPanel.Dock="Left"
                                Width="4"
                                CornerRadius="2"
                                Background="{DynamicResource SuccessBrush}"
                                Margin="0,1,10,1" />
                        <TextBlock Style="{StaticResource SectionTitle}"
                                   Text="波形预览"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!--
           预览区域：WpfPlot 作为真正的交互式控件。
           加载中 / 空状态时在 WpfPlot 上方叠加覆盖层。
       -->
                    <Grid Grid.Row="1"
                          MinHeight="280">

                        <!-- 圆角背景框 -->
                        <Border Background="{DynamicResource ThirdlyRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8" />

                        <!-- ScottPlot.WPF 交互式信号图（始终渲染，样式由 ViewModel 初始化） -->
                        <scottplot:WpfPlot x:Name="WaveformPlot"
                                           Margin="1"
                                           Background="{DynamicResource TransparentBrush}" />

                        <!-- 加载中覆盖层 -->
                        <Border Background="{DynamicResource ThirdlyRegionBrush}"
                                Opacity="0.85"
                                CornerRadius="8"
                                Margin="1"
                                IsHitTestVisible="False"
                                Visibility="{Binding IsLoadingPreview, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <Border Width="16"
                                        Height="16"
                                        Margin="0,0,8,0">
                                    <Border.RenderTransformOrigin>0.5, 0.5</Border.RenderTransformOrigin>
                                    <Border.RenderTransform>
                                        <RotateTransform />
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:0.9" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Ellipse Width="14"
                                             Height="14"
                                             Stroke="{DynamicResource PrimaryBrush}"
                                             StrokeThickness="2.5"
                                             StrokeDashArray="9 3" />
                                </Border>
                                <TextBlock Text="正在加载波形…"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- 空状态占位（无数据且未在加载时） -->
                        <TextBlock Text="请添加文件以预览波形"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThirdlyTextBrush}"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding ShowEmptyPlaceholder, Converter={StaticResource BoolToVis}}" />

                    </Grid>

                    <!-- 错误消息行（仅 PreviewStatus 非空时显示） -->
                    <TextBlock Text="{Binding PreviewStatus}" Grid.Row="2"
                               FontSize="12"
                               Foreground="{DynamicResource DangerBrush}"
                               Margin="0,6,0,0"
                               Visibility="{Binding HasPreviewStatus, Converter={StaticResource BoolToVis}}" />

              
            </Grid>
            
         
        </Border>

    </Grid>
</UserControl>

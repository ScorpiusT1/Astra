<?xml version="1.0" encoding="utf-8"?>
<AddinManifest>
	<Schema>http://pluginsystem.org/schema/v1</Schema>
	<Addin>
		<Id>Astra.Plugins.WorkflowArchive</Id>
		<Name>结果归档插件</Name>
		<Version>1.0.0</Version>
		<Description>流程内显式触发测试结果归档（TDMS/WAV/CSV/JSON；HTML/PDF 报告实现与本插件 Reporting 程序集同源，由宿主注册 ITestReportGenerator）</Description>
		<Author>Astra Team</Author>
		<Copyright>Copyright © Astra Team</Copyright>
		<Website />
		<IconPath>FileExport</IconPath>
		<Order>8</Order>
		<Runtime>
			<Assembly>Astra.Plugins.WorkflowArchive.dll</Assembly>
			<TypeName>Astra.Plugins.WorkflowArchive.WorkflowArchivePlugin</TypeName>
			<TargetFramework>net8.0-windows</TargetFramework>
		</Runtime>
		<Dependencies />
		<Permissions>
			<Required />
		</Permissions>
	</Addin>
	<Nodes>
		<NodeInfo
			Name="测试结果归档"
			TypeName="Astra.Plugins.WorkflowArchive.Nodes.WorkflowArchiveNode"
			IconCode="FileExport"
			Description="调用统一归档服务（TDMS/WAV/CSV/HTML）；失败场景由引擎在释放 Raw 前兜底"
			Category="测试/输出" />
		<NodeInfo
			Name="归档（全部子流程）"
			TypeName="Astra.Plugins.WorkflowArchive.Nodes.ArchiveAllSubWorkflowsNode"
			IconCode="FileExport"
			Description="与「测试结果归档」相同；报告白名单可选全部子流程内节点（子流程名/节点名）"
			Category="测试/输出" />
	</Nodes>
</AddinManifest>

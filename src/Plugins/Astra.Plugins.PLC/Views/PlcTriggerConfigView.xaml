<UserControl x:Class="Astra.Plugins.PLC.Views.PlcTriggerConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Thickness x:Key="CardSpacing">0,14,0,0</Thickness>
        <Thickness x:Key="FieldSpacing">0,8,0,0</Thickness>
        <Thickness x:Key="ColumnGap">16,0,0,0</Thickness>

        <Style x:Key="PageTitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="20" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,2" />
        </Style>
        <Style x:Key="PageSubtitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Opacity"
                    Value="0.78" />
            <Setter Property="Foreground"
                    Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style x:Key="ModernFormTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource DefaultModernTextBoxStyle}">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="MinWidth"
                    Value="220" />
            <Setter Property="Margin"
                    Value="{StaticResource FieldSpacing}" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
        </Style>

        <Style x:Key="ModernFormComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource ModernComboBoxStyle}">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="MinWidth"
                    Value="220" />
            <Setter Property="Margin"
                    Value="{StaticResource FieldSpacing}" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,6">
            <TextBlock Text="PLC 触发器配置"
                       Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="选择 PLC 设备与监控 IO（与 PLC / IO 配置一致）。可配置防重复与最小间隔。"
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="基本"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical">
                        <TextBlock Text="配置名称"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.ConfigName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <CheckBox Grid.Column="1"
                              Margin="18,22,0,0"
                              Content="启用"
                              VerticalAlignment="Center"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              IsChecked="{Binding Config.IsEnabled, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="PLC 与监控 IO"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical">
                        <TextBlock Text="PLC 设备"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox Style="{StaticResource ModernFormComboBoxStyle}"
                                  ItemsSource="{Binding PlcDeviceNames}"
                                  SelectedItem="{Binding Config.PlcDeviceName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="监控 IO（IO 配置）"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox Style="{StaticResource ModernFormComboBoxStyle}"
                                  ItemsSource="{Binding IoPointNames}"
                                  SelectedItem="{Binding Config.IoPointName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="重复触发"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0"
                              Content="限制短时间内对相同信号的重复触发"
                              VerticalAlignment="Center"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              IsChecked="{Binding Config.AntiRepeat.Enabled, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Row="1"
                                Orientation="Vertical"
                                Margin="0,12,0,0">
                        <TextBlock Text="相同信号最小间隔 (ms)"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 MinWidth="160"
                                 Text="{Binding Config.AntiRepeat.MinIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThirdlyTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="在间隔内若再次收到同一信号（如同一条码），将忽略；关闭「限制重复」则不校验间隔。" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

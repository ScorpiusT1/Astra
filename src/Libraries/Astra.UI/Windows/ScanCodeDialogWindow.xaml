<Window x:Class="Astra.UI.Windows.ScanCodeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Astra.UI.Helpers"
        Title="扫码"
        Width="440"
        SizeToContent="Height"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="1.5"
            helpers:BorderClipHelper.ClipToBounds="True"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}"
                              Opacity="0.2"
                              BlurRadius="24"
                              ShadowDepth="5" />
        </Border.Effect>

        <Grid Margin="24,16,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button x:Name="CloseButton"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-8,-8,0"
                    Panel.ZIndex="10"
                    Style="{StaticResource CloseButtonStyle}"
                    Click="CloseButton_Click" />

            <TextBlock Grid.Row="0"
                       Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,6" />

            <TextBlock x:Name="PromptTextBlock"
                       Grid.Row="1"
                       Text="请使用扫码枪扫描，或手动输入后按回车确认。"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8" />

            <TextBlock Grid.Row="2"
                       Text="条码 / 二维码内容"
                       FontSize="12"
                       Foreground="{DynamicResource ThirdlyTextBrush}"
                       Margin="0,0,0,4" />

            <TextBox x:Name="ScanTextBox"
                     Grid.Row="3"
                     Style="{StaticResource ModernTextBoxStyle}"
                     VerticalContentAlignment="Center"
                     Margin="0,8,0,8"
                     PreviewKeyDown="ScanTextBox_PreviewKeyDown"
                     TextChanged="ScanTextBox_TextChanged" />

            <TextBlock x:Name="LengthHintTextBlock"
                       Grid.Row="4"
                       FontSize="11"
                       Foreground="{DynamicResource ThirdlyTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />

            <TextBlock x:Name="ValidationTextBlock"
                       Grid.Row="5"
                       FontSize="12"
                       Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,8" />

            <TextBlock Grid.Row="6"
                       Text="提示：多数扫码枪模拟键盘输入，扫描结束会自动附加回车。"
                       FontSize="11"
                       Foreground="{DynamicResource ThirdlyTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="取消"
                        MinWidth="96"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"
                        IsCancel="True" />
                <Button x:Name="OkButton"
                        Content="确定"
                        MinWidth="96"
                        Height="36"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="OkButton_Click"
                        IsDefault="True"
                        IsEnabled="False" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<hc:Window x:Class="Astra.UI.Windows.NodePropertyEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:ui="clr-namespace:Astra.UI.Controls"
        Title="节点属性"
        SizeToContent="Manual"
        Width="820"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        NonClientAreaBackground="{DynamicResource SurfaceBrush}"
        NonClientAreaForeground="{DynamicResource PrimaryTextBrush}"
        ShowIcon="False"
        ShowInTaskbar="True"
        >
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 属性编辑器主体 -->
        <ScrollViewer Grid.Row="0"
                      Margin="0,0,0,16"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False">
            <ui:PropertyEditorControl x:Name="PropertyEditor"
                                      ShowSearchBox="False"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
        </ScrollViewer>

        <!-- 底部确认 / 取消按钮 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                <Button Content="取消"
                        Width="120"
                        Height="44"
                        Margin="0,0,12,0"
                        Click="CancelButton_Click"
                        Background="{DynamicResource ThirdlyRegionBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        FontSize="14"
                        FontWeight="Medium"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="20,10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="{DynamicResource SecondaryRegionBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="确定"
                        Width="120"
                        Height="44"
                        Click="OkButton_Click"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource ReverseTextBrush}"
                        FontSize="14"
                        FontWeight="Medium"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="20,10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="{DynamicResource DarkPrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
        </StackPanel>
    </Grid>
</hc:Window>


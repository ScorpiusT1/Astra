<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 依赖：先合并 CommonStyles（ModernCardStyle）、HomeModuleStyles（标题条渐变） -->

    <Style x:Key="DataQueryPageTitleStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SectionTitleStyle}">
        <Setter Property="FontSize"
                Value="22" />
        <Setter Property="Margin"
                Value="0,0,0,2" />
    </Style>

    <Style x:Key="DataQuerySubtitleStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="13" />
        <Setter Property="Foreground"
                Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="TextWrapping"
                Value="Wrap" />
        <Setter Property="LineHeight"
                Value="22" />
    </Style>

    <Style x:Key="DataQueryFieldLabelStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="Foreground"
                Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="0,0,10,0" />
    </Style>

    <!-- 筛选区：基于 ModernCardStyle，略紧凑 -->
    <Style x:Key="DataQueryFilterCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource ModernCardStyle}">
        <Setter Property="Padding"
                Value="20,18" />
        <Setter Property="Margin"
                Value="0,0,0,16" />
    </Style>

    <!-- 结果表格容器：底部分隔更清晰 -->
    <Style x:Key="DataQueryGridHostStyle"
           TargetType="Border"
           BasedOn="{StaticResource ModernCardStyle}">
        <Setter Property="Padding"
                Value="0,0,0,8" />
        <Setter Property="ClipToBounds"
                Value="True" />
    </Style>

    <!-- 页头左侧色条（与首页模块标题气质一致） -->
    <Style x:Key="DataQueryTitleAccentStripeStyle"
           TargetType="Border">
        <Setter Property="Width"
                Value="4" />
        <Setter Property="CornerRadius"
                Value="2" />
        <Setter Property="Margin"
                Value="0,2,14,2" />
        <Setter Property="Background"
                Value="{DynamicResource HomeModuleTitleInfoToPrimaryBrush}" />
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 标题左侧：信息色 → 主色（与良率模块标题条一致） -->
    <LinearGradientBrush x:Key="HomeModuleTitleInfoToPrimaryBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Color="{DynamicResource InfoColor}"
                      Offset="0" />
        <GradientStop Color="{DynamicResource PrimaryColor}"
                      Offset="1" />
    </LinearGradientBrush>

    <!-- IO 监控：右上角点位数量胶囊 -->
    <Style x:Key="IoMonitorHeaderCountPillStyle"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="10" />
        <Setter Property="Padding"
                Value="8,3" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource InfoColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource InfoColorFillTint}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IO 监控：单格卡片外框 -->
    <Style x:Key="IoMonitorPointCardStyle"
           TargetType="Border">
        <Setter Property="MinHeight"
                Value="72" />
        <Setter Property="Margin"
                Value="3" />
        <Setter Property="CornerRadius"
                Value="6" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="ClipToBounds"
                Value="True" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource DangerColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,0">
                    <GradientStop Color="{DynamicResource IoMonitorNeutralGradientStart}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource IoMonitorNeutralGradientEnd}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOn}"
                         Value="True">
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="{DynamicResource SuccessColorBorderTint}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Color="{DynamicResource IoMonitorOnGradientStart}"
                                          Offset="0" />
                            <GradientStop Color="{DynamicResource IoMonitorOnGradientEnd}"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- IO 监控：左侧状态竖条 -->
    <Style x:Key="IoMonitorLeftStripeStyle"
           TargetType="Border">
        <Setter Property="Width"
                Value="4" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="CornerRadius"
                Value="6,0,0,6" />
        <Setter Property="Background"
                Value="{DynamicResource DangerBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOn}"
                         Value="True">
                <Setter Property="Background"
                        Value="{DynamicResource SuccessBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- IO 监控：数值文字 -->
    <Style x:Key="IoMonitorValueTextStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="17" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="Margin"
                Value="0,1,0,0" />
        <Setter Property="TextTrimming"
                Value="CharacterEllipsis" />
        <Setter Property="Foreground"
                Value="{DynamicResource DangerBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOn}"
                         Value="True">
                <Setter Property="Foreground"
                        Value="{DynamicResource DarkSuccessBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- IO 监控：右上角状态点 -->
    <Style x:Key="IoMonitorStatusDotStyle"
           TargetType="Ellipse">
        <Setter Property="Width"
                Value="6" />
        <Setter Property="Height"
                Value="6" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="0,6,6,0" />
        <Setter Property="Fill"
                Value="{DynamicResource DangerBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOn}"
                         Value="True">
                <Setter Property="Fill"
                        Value="{DynamicResource SuccessBrush}" />
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever"
                                    AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1"
                                             To="0.3"
                                             Duration="0:0:1" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 良率：进度条 -->
    <Style x:Key="YieldModuleProgressBarStyle"
           TargetType="ProgressBar">
        <Setter Property="Height"
                Value="6" />
        <Setter Property="Background"
                Value="{DynamicResource LightSuccessBrush}" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="3"
                            Background="{TemplateBinding Background}">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="{DynamicResource SuccessColor}"
                                                      Offset="0" />
                                        <GradientStop Color="{DynamicResource InfoColor}"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <LinearGradientBrush x:Key="YieldStatCardWarningStripeBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Color="{DynamicResource WarningColor}"
                      Offset="0" />
        <GradientStop Color="{DynamicResource DarkWarningColor}"
                      Offset="1" />
    </LinearGradientBrush>

    <!-- 良率：总测试数 -->
    <Style x:Key="YieldStatCardTotalStyle"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="8" />
        <Setter Property="Height"
                Value="76" />
        <Setter Property="Margin"
                Value="0,0,4,4" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource PrimaryColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="{DynamicResource PrimaryColorCardWash}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource TransparentColor}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 良率：通过数 -->
    <Style x:Key="YieldStatCardPassStyle"
           TargetType="Border"
           BasedOn="{StaticResource YieldStatCardTotalStyle}">
        <Setter Property="Margin"
                Value="4,0,0,4" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SuccessColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="{DynamicResource SuccessColorCardWash}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource TransparentColor}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 良率：失败数 -->
    <Style x:Key="YieldStatCardFailStyle"
           TargetType="Border"
           BasedOn="{StaticResource YieldStatCardTotalStyle}">
        <Setter Property="Margin"
                Value="0,0,4,0" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource DangerColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="{DynamicResource DangerColorCardWash}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource TransparentColor}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 良率：当前良率 -->
    <Style x:Key="YieldStatCardCurrentYieldStyle"
           TargetType="Border"
           BasedOn="{StaticResource YieldStatCardTotalStyle}">
        <Setter Property="Margin"
                Value="4,0,0,0" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource WarningColorBorderTint}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="{DynamicResource WarningColorCardWash}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource TransparentColor}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="YieldStatCardPrimaryStripeStyle"
           TargetType="Border">
        <Setter Property="Width"
                Value="4" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="CornerRadius"
                Value="8,0,0,8" />
        <Setter Property="Background"
                Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style x:Key="YieldStatCardSuccessStripeStyle"
           TargetType="Border"
           BasedOn="{StaticResource YieldStatCardPrimaryStripeStyle}">
        <Setter Property="Background"
                Value="{DynamicResource SuccessBrush}" />
    </Style>

    <Style x:Key="YieldStatCardDangerStripeStyle"
           TargetType="Border"
           BasedOn="{StaticResource YieldStatCardPrimaryStripeStyle}">
        <Setter Property="Background"
                Value="{DynamicResource DangerBrush}" />
    </Style>

    <Style x:Key="YieldStatCardWarningStripeBorderStyle"
           TargetType="Border">
        <Setter Property="Width"
                Value="4" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="CornerRadius"
                Value="8,0,0,8" />
        <Setter Property="Background"
                Value="{DynamicResource YieldStatCardWarningStripeBrush}" />
    </Style>

    <Style x:Key="YieldStatCardMetricLabelStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="Foreground"
                Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="Margin"
                Value="0,0,0,2" />
    </Style>

    <Style x:Key="YieldStatCardMetricValuePrimaryStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="24" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="Foreground"
                Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style x:Key="YieldStatCardMetricValueSuccessStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource YieldStatCardMetricValuePrimaryStyle}">
        <Setter Property="Foreground"
                Value="{DynamicResource SuccessBrush}" />
    </Style>

    <Style x:Key="YieldStatCardMetricValueDangerStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource YieldStatCardMetricValuePrimaryStyle}">
        <Setter Property="Foreground"
                Value="{DynamicResource DangerBrush}" />
    </Style>

    <Style x:Key="YieldStatCardMetricValueWarningStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource YieldStatCardMetricValuePrimaryStyle}">
        <Setter Property="FontSize"
                Value="26" />
        <Setter Property="Foreground"
                Value="{DynamicResource WarningBrush}" />
    </Style>

    <Style x:Key="YieldStatCardContentPanelStyle"
           TargetType="StackPanel">
        <Setter Property="Margin"
                Value="12,0,8,0" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
    </Style>

</ResourceDictionary>

<UserControl x:Class="Astra.Views.SoftwareConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Astra.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:SoftwareConfigViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <!-- 局部统一：留白、控件高度、视觉层次（不改动业务绑定） -->
        <Thickness x:Key="PagePadding">20</Thickness>
        <Thickness x:Key="CardSpacing">0,14,0,0</Thickness>
        <Thickness x:Key="FieldSpacing">0,8,0,0</Thickness>
        <Thickness x:Key="ColumnGap">16,0,0,0</Thickness>
        <CornerRadius x:Key="SurfaceCornerRadius">10</CornerRadius>

        <Style x:Key="PageTitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="20" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,2" />
        </Style>
        <Style x:Key="PageSubtitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Opacity"
                    Value="0.78" />
            <Setter Property="Foreground"
                    Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <!-- 基于现有全局样式做局部统一（避免影响其它页面） -->
        <Style x:Key="ModernFormTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource DefaultModernTextBoxStyle}">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="MinWidth"
                    Value="140" />
            <Setter Property="Margin"
                    Value="{StaticResource FieldSpacing}" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 页面标题区 -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,6">
            <TextBlock Text="软件配置"
                       Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="配置线体、工站信息及 Slot/Group 与测试脚本/触发器的映射关系。"
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <!-- 基本信息卡片 -->
        <Border Grid.Row="1"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="软件信息"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                VerticalAlignment="Center">
                        <TextBlock Text="线体名称"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.LineName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}"
                                VerticalAlignment="Center">
                        <TextBlock Text="工站名称"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.StationName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 测试配置卡片 -->
        <Border Grid.Row="2"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="测试配置"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical">
                        <TextBlock Text="Group 数量"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.GroupCount, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="每组 Slot 数"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.SlotCount, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="总 Slot（=Group×Slot）"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 IsReadOnly="True"
                                 Opacity="0.85"

                                 Text="{Binding Config.DutCount}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2"
                            Margin="{StaticResource FieldSpacing}"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <CheckBox IsChecked="{Binding Config.EnableHomeSequenceLinkage, UpdateSourceTrigger=PropertyChanged}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="启用 Home 与流程编辑界面执行联动（开始/暂停/继续/取消）"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 测试映射关系 -->
        <Border Grid.Row="3"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="测试脚本 / 触发器映射"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <!-- 表格用“表面容器”增强边界与层次 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource SurfaceCornerRadius}"
                        Padding="8">
                    <DataGrid ItemsSource="{Binding Config.Duts}"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource ThirdlyRegionBrush}"
                              AlternationCount="2"
                              IsReadOnly="False"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.CanContentScroll="True"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号"
                                                Width="64"
                                                Binding="{Binding Index}"
                                                IsReadOnly="True" />

                            <!-- 只配置“测试脚本/触发器”：使用 ComboBox -->
                            <DataGridTemplateColumn Header="测试脚本"
                                                    Width="*"
                                                    MinWidth="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEditable="False"
                                                  ItemsSource="{Binding DataContext.WorkflowOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Name"

                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding WorkflowId, UpdateSourceTrigger=PropertyChanged}"
                                                  Text="{Binding WorkflowName, Mode=OneWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="触发器"
                                                    Width="*"
                                                    MinWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEditable="True"
                                                  ItemsSource="{Binding DataContext.TriggerOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding TriggerConfigId, UpdateSourceTrigger=PropertyChanged}"
                                                  Text="{Binding TriggerName, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>


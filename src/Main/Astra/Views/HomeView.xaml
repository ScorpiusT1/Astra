<UserControl x:Class="Astra.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:Astra.ViewModels"
             xmlns:moduleViews="clr-namespace:Astra.Views.HomeModules"
             d:DataContext="{d:DesignInstance Type=viewmodels:HomeViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <Grid Margin="14">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <Style x:Key="HomeRegionCardStyle"
                   TargetType="Border">
                <Setter Property="Background"
                        Value="{DynamicResource RegionBrush}" />
                <Setter Property="BorderBrush"
                        Value="{DynamicResource BorderBrush}" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="CornerRadius"
                        Value="12" />
                <Setter Property="Padding"
                        Value="4" />
                <Setter Property="VerticalAlignment"
                        Value="Stretch" />
            </Style>

            <Style x:Key="HomeActionButtonBaseStyle"
                   TargetType="Button">
                <Setter Property="Height"
                        Value="36" />
                <Setter Property="FontSize"
                        Value="13" />
                <Setter Property="FontWeight"
                        Value="SemiBold" />
                <Setter Property="Padding"
                        Value="12,0" />
                <Setter Property="Foreground"
                        Value="{DynamicResource ReverseTextBrush}" />
                <Setter Property="BorderThickness"
                        Value="0" />
                <Setter Property="Cursor"
                        Value="Hand" />
                <Setter Property="Background"
                        Value="{DynamicResource PrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="ButtonBorder"
                                            Property="Opacity"
                                            Value="0.9" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="ButtonBorder"
                                            Property="Opacity"
                                            Value="0.78" />
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                    <Setter TargetName="ButtonBorder"
                                            Property="Opacity"
                                            Value="0.45" />
                                    <Setter Property="Cursor"
                                            Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HomeStartButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource HomeActionButtonBaseStyle}">
                <Setter Property="Background"
                        Value="{DynamicResource SuccessBrush}" />
            </Style>

            <Style x:Key="HomeCancelButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource HomeActionButtonBaseStyle}">
                <Setter Property="Background"
                        Value="{DynamicResource DangerBrush}" />
            </Style>

            <Style x:Key="HomePauseButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource HomeActionButtonBaseStyle}">
                <Setter Property="Background"
                        Value="{DynamicResource WarningBrush}" />
            </Style>

            <Style x:Key="HomeResumeButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource HomeActionButtonBaseStyle}">
                <Setter Property="Background"
                        Value="{DynamicResource PrimaryBrush}" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                  Opacity="0.12"
                                  ShadowDepth="2"
                                  BlurRadius="14"
                                  Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <!-- Auto：按模块自然高度占位；勿用默认 *，否则与日志行分星高后 IO 区过矮且内部 ScrollViewer 无法形成有限视口 -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="6"
                        Padding="14,12"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="{DynamicResource LightPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                             Value="OK">
                                    <Setter Property="Background"
                                            Value="{DynamicResource LightSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                             Value="NG">
                                    <Setter Property="Background"
                                            Value="{DynamicResource LightDangerBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="4"
                                        CornerRadius="2"
                                        Margin="0,0,8,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="0,1">
                                            <GradientStop Color="{DynamicResource InfoColor}"
                                                          Offset="0" />
                                            <GradientStop Color="{DynamicResource PrimaryColor}"
                                                          Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="测试总结果"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TitleBrush}" />
                            </Grid>
                            <TextBlock Text="{Binding TestItemTreeModule.SummaryResult}"
                                       Margin="0,6,0,0"
                                       FontSize="42"
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                                         Value="OK">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource DarkSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                                         Value="NG">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource DarkDangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1"
                                MinWidth="78"
                                Height="34"
                                CornerRadius="17"
                                Padding="14,5"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource SecondaryBorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                                     Value="OK">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TestItemTreeModule.SummaryResult}"
                                                     Value="NG">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource DangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding TestItemTreeModule.SummaryResult}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ReverseTextBrush}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <moduleViews:YieldModuleView Grid.Row="1"
                                             DataContext="{Binding YieldModule}" />

                <moduleViews:IOMonitorModuleView Grid.Row="2"
                                                 DataContext="{Binding IoMonitorModule}"
                                                 Visibility="{Binding HasMonitorPoints,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisibilityConverter}}" />

                <moduleViews:RealTimeLogModuleView Grid.Row="3"
                                                   DataContext="{Binding RealTimeLogModule}" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                  Opacity="0.12"
                                  ShadowDepth="2"
                                  BlurRadius="14"
                                  Direction="270" />
            </Border.Effect>
            <moduleViews:TestItemTreeModuleView DataContext="{Binding TestItemTreeModule}" />
        </Border>
    </Grid>
</UserControl>

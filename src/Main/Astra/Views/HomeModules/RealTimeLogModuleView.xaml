<UserControl x:Class="Astra.Views.HomeModules.RealTimeLogModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Astra.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">

    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

        <!-- 卡片背景渐变（末端保留淡色，不完全透明） -->
        <LinearGradientBrush x:Key="InfoCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <GradientStop Color="#3000B4D8"
                          Offset="0" />
            <GradientStop Color="#1800B4D8"
                          Offset="0.5" />
            <GradientStop Color="#0D00B4D8"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="WarnCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <GradientStop Color="#38F59E0B"
                          Offset="0" />
            <GradientStop Color="#20F59E0B"
                          Offset="0.5" />
            <GradientStop Color="#12F59E0B"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ErrorCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <GradientStop Color="#38EF4444"
                          Offset="0" />
            <GradientStop Color="#20EF4444"
                          Offset="0.5" />
            <GradientStop Color="#12EF4444"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FatalCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <GradientStop Color="#40F97316"
                          Offset="0" />
            <GradientStop Color="#25F97316"
                          Offset="0.5" />
            <GradientStop Color="#15F97316"
                          Offset="1" />
        </LinearGradientBrush>

        <!-- 日志条目 DataTemplate -->
        <DataTemplate x:Key="LogItemTemplate">
            <Border Margin="0,4"
                    Padding="0"
                    MinHeight="82"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6"
                                      ShadowDepth="1"
                                      Direction="270"
                                      Opacity="0.08"
                                      Color="#000000" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="8" />
                        <Setter Property="Background"
                                Value="{StaticResource InfoCardBg}" />
                        <Setter Property="BorderThickness"
                                Value="0,0,0,0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="WARN">
                                <Setter Property="Background"
                                        Value="{StaticResource WarnCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="ERROR">
                                <Setter Property="Background"
                                        Value="{StaticResource ErrorCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="FATAL">
                                <Setter Property="Background"
                                        Value="{StaticResource FatalCardBg}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧 4px 实色竖线 -->
                    <Border Grid.Column="0"
                            CornerRadius="8,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="#00B4D8" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="WARN">
                                        <Setter Property="Background"
                                                Value="#F59E0B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="ERROR">
                                        <Setter Property="Background"
                                                Value="#EF4444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="FATAL">
                                        <Setter Property="Background"
                                                Value="#F97316" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- 中间：时间戳 + 消息 -->
                    <StackPanel Grid.Column="1"
                                Margin="12,10,8,10"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,13" />
                        <TextBlock Text="{Binding Message}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   MaxHeight="40"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- 右侧 Badge：实色背景 + 白色文字 -->
                    <Border Grid.Column="2"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            CornerRadius="4"
                            Padding="0,3"
                            MinWidth="52">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="#00B4D8" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="WARN">
                                        <Setter Property="Background"
                                                Value="#F59E0B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="ERROR">
                                        <Setter Property="Background"
                                                Value="#EF4444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="FATAL">
                                        <Setter Property="Background"
                                                Value="#F97316" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding NormalizedLevel}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                    </Border>

                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="0"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <DockPanel Background="{DynamicResource RegionBrush}">

        <!-- 标题栏 -->
        <Grid DockPanel.Dock="Top"
              Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧渐变装饰条 -->
            <Border Grid.Column="0"
                    Width="4"
                    Height="18"
                    CornerRadius="2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">
                        <GradientStop Color="#06B6D4"
                                      Offset="0" />
                        <GradientStop Color="#3B82F6"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <TextBlock Grid.Column="1"
                       Text="实时日志记录模块"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TitleBrush}" />

            <!-- 右侧日志计数 Badge -->
            <Border Grid.Column="2"
                    CornerRadius="10"
                    Padding="8,3"
                    VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="#1406B6D4" />
                </Border.Background>
                <Border BorderBrush="#3306B6D4"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="{Binding Logs.Count, Mode=OneWay}" /><Run Text=" 条" />
                    </TextBlock>
                </Border>
            </Border>
        </Grid>
        <TextBlock DockPanel.Dock="Top"
                   Text="展示最新日志级别、时间与消息内容。"
                   Margin="16,0,16,8"
                   FontSize="12"
                   LineHeight="18"
                   Foreground="{DynamicResource SecondaryTextBrush}" />

        <!-- 分割线 -->
        <Border DockPanel.Dock="Top"
                Height="1"
                Margin="16,0,16,8"
                Background="{DynamicResource BorderBrush}"
                Opacity="0.35" />

        <!-- 列表区 -->
        <Grid>
            <!-- 空状态 -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding Logs.Count,
                            Converter={StaticResource CountToVisibilityConverter}}">
                <Ellipse Width="36"
                         Height="36"
                         Stroke="{DynamicResource SecondaryTextBrush}"
                         StrokeThickness="2"
                         StrokeDashArray="2.5,8"
                         Margin="0,0,0,10">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinTransform"
                                         CenterX="18"
                                         CenterY="18" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="等待日志数据…"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- 日志列表 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,0,16,12">
                <ItemsControl ItemsSource="{Binding Logs}"
                              ItemTemplate="{StaticResource LogItemTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin"
                                    Value="0,0,0,1" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        </DockPanel>
    </Border>
</UserControl>
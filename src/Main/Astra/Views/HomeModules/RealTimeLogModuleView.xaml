<UserControl x:Class="Astra.Views.HomeModules.RealTimeLogModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:conv="clr-namespace:Astra.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">

    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <!-- 空状态路径：日志面板外框 + 左侧色带位 + 多行横线（模拟日志文本流），与「实时日志」语义一致 -->
        <Geometry x:Key="LogEmptyStateGeometry">F1 M 88,96 L 936,96 Q 952,96 952,112 L 952,912 Q 952,928 936,928 L 88,928 Q 72,928 72,912 L 72,112 Q 72,96 88,96 Z M 152,168 L 152,832 M 208,232 L 848,232 M 208,312 L 784,312 M 208,392 L 816,392 M 208,472 L 736,472 M 208,552 L 864,552 M 208,632 L 768,632 M 208,712 L 832,712 M 208,792 L 888,792</Geometry>

        <!-- 卡片背景渐变（末端保留淡色，不完全透明） -->
        <LinearGradientBrush x:Key="InfoCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.4">
            <GradientStop Color="{DynamicResource SuccessColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightSuccessColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="WarnCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.4">
            <GradientStop Color="{DynamicResource WarningColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightWarningColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ErrorCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.40">
            <GradientStop Color="{DynamicResource DangerColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightDangerColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FatalCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.40">
            <GradientStop Color="{DynamicResource DarkWarningColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightDangerColor}"
                          Offset="1" />
        </LinearGradientBrush>

        <!-- 日志条目 DataTemplate -->
        <DataTemplate x:Key="LogItemTemplate">
            <Border Margin="0,4"
                    Padding="0"
                    MinHeight="82"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6"
                                      ShadowDepth="1"
                                      Direction="270"
                                      Opacity="0.08"
                                      Color="{DynamicResource ShadowColor}" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="8" />
                        <Setter Property="Background"
                                Value="{StaticResource InfoCardBg}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="WARN">
                                <Setter Property="Background"
                                        Value="{StaticResource WarnCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="ERROR">
                                <Setter Property="Background"
                                        Value="{StaticResource ErrorCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="FATAL">
                                <Setter Property="Background"
                                        Value="{StaticResource FatalCardBg}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧 4px 实色竖线 -->
                    <Border Grid.Column="0"
                            CornerRadius="8,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource DarkSuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="WARN">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkWarningBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="ERROR">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkDangerBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="FATAL">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkDangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- 首行：时间戳靠左，级别徽章靠右；次行为消息 -->
                    <Grid Grid.Column="1"
                          Margin="12,10,12,10"
                          VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              Margin="0,0,0,10"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    CornerRadius="4"
                                    Padding="10,4"
                                    MinWidth="52"
                                    HorizontalAlignment="Right">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                                         Value="WARN">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource WarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                                         Value="ERROR">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                                         Value="FATAL">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource DarkWarningBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding NormalizedLevel}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ReverseTextBrush}"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding Message}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   TextTrimming="None" />
                    </Grid>

                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="4"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="清除日志"
                          Command="{Binding ClearLogsCommand}" />
            </ContextMenu>
        </Border.ContextMenu>
        <!-- 用 Grid 替代 DockPanel：行高语义更直观，日志区可用 * 行占满标题下方的剩余高度 -->
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0"
              Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


                <Border Grid.Column="0"
                        Width="4"
                        CornerRadius="2"
                        Margin="0,0,10,0"
                        Background="{StaticResource HomeModuleTitleInfoToPrimaryBrush}" />

                <TextBlock Grid.Column="1"
                       Text="实时日志记录模块"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TitleBrush}" />

            <!-- 右侧日志计数 Badge -->
            <Border Grid.Column="2"
                    CornerRadius="10"
                    Padding="8,3"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource LightPrimaryColor}" />
                </Border.Background>
                <Border BorderBrush="{DynamicResource PrimaryBrush}"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="0">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="{Binding VisibleLogCount, Mode=OneWay}" /><Run Text=" 条" />
                    </TextBlock>
                </Border>
            </Border>
        </Grid>
        <TextBlock Grid.Row="1"
                   Text="展示最新日志级别、时间与消息内容。"
                   Margin="16,0,16,6"
                   FontSize="12"
                   LineHeight="18"
                   Foreground="{DynamicResource SecondaryTextBrush}" />

        <!-- 级别筛选：默认仅警告 + 错误；勾选「信息」可查看 INFO / DEBUG 等 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="16,0,16,8"
                    VerticalAlignment="Center">
            <TextBlock Text="显示级别："
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <CheckBox Content="信息"
                      IsChecked="{Binding ShowInfoLogs, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0"
                      FontSize="12"
                      Foreground="{DynamicResource PrimaryTextBrush}" />
            <CheckBox Content="警告"
                      IsChecked="{Binding ShowWarnLogs, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0"
                      FontSize="12"
                      Foreground="{DynamicResource PrimaryTextBrush}" />
            <CheckBox Content="错误"
                      IsChecked="{Binding ShowErrorLogs, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      FontSize="12"
                      Foreground="{DynamicResource PrimaryTextBrush}" />
        </StackPanel>

        <!-- 日志区：单独 ScrollViewer，限制高度后列表在模块内滚动（左侧栏不再整体滚动） -->
        <ScrollViewer Grid.Row="3"
                      VerticalAlignment="Stretch"
                    
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      Padding="16,0,16,12">
            <!-- 无日志时抬高 MinHeight，配合 * / Auto / * 才能在 ScrollViewer 可视区内真正垂直居中（否则内容高度测量为无限，Center 无效） -->
            <Grid>
                <!--<Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="MinHeight"
                                Value="120" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Logs.Count}"
                                         Value="0">
                                <Setter Property="MinHeight"
                                        Value="360" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>-->

                <ItemsControl ItemsSource="{Binding FilteredLogs}"
                              ItemTemplate="{StaticResource LogItemTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin"
                                    Value="0,0,0,1" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>

                <!-- 空状态：三行布局使中间块在剩余高度内垂直居中 -->
                <Grid Visibility="{Binding VisibleLogCount, Converter={StaticResource CountToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center">
                        <hc:TransitioningContentControl HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center">
                            <Viewbox Width="112"
                                     Height="112"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Stretch="Uniform">
                                <hc:AnimationPath HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Duration="0:0:4.5"
                                                  Stretch="Uniform"
                                                  Width="1024"
                                                  Height="1024"
                                                  StrokeThickness="14"
                                                  Opacity="0.42"
                                                  Stroke="{DynamicResource PrimaryBrush}"
                                                  Data="{StaticResource LogEmptyStateGeometry}" />
                            </Viewbox>
                        </hc:TransitioningContentControl>
                        <TextBlock Text="等待日志数据…"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Opacity="0.5"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
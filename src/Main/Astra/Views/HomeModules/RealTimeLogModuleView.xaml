<UserControl x:Class="Astra.Views.HomeModules.RealTimeLogModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:conv="clr-namespace:Astra.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">

    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <Geometry x:Key="GithubGeometry">F1 M 512,64 C 268,64 72,260 72,504 C 72,700 200,867 377,926 C 402,931 411,916 411,903 C 411,892 410,860 410,819 C 272,849 243,761 243,761 C 220,703 187,687 187,687 C 142,656 191,657 191,657 C 241,661 267,709 267,709 C 311,784 383,763 411,750 C 415,717 428,695 442,683 C 332,670 217,628 217,440 C 217,387 236,344 267,309 C 262,297 245,247 272,180 C 272,180 314,166 410,232 C 449,221 490,215 531,215 C 572,215 613,221 652,232 C 748,166 790,180 790,180 C 817,247 800,297 795,309 C 826,344 845,387 845,440 C 845,629 729,669 619,683 C 637,699 653,730 653,777 C 653,845 652,888 652,903 C 652,916 661,932 686,926 C 863,867 992,700 992,504 C 992,260 796,64 552,64 C 538,64 525,64 512,64 Z</Geometry>

        <!-- 卡片背景渐变（末端保留淡色，不完全透明） -->
        <LinearGradientBrush x:Key="InfoCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.4">
            <GradientStop Color="{DynamicResource SuccessColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightSuccessColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="WarnCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.4">
            <GradientStop Color="{DynamicResource WarningColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightWarningColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ErrorCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.40">
            <GradientStop Color="{DynamicResource DangerColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightDangerColor}"
                          Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FatalCardBg"
                             StartPoint="0,0"
                             EndPoint="1,0"
                             Opacity="0.40">
            <GradientStop Color="{DynamicResource DarkWarningColor}"
                          Offset="0" />
            <GradientStop Color="{DynamicResource LightDangerColor}"
                          Offset="1" />
        </LinearGradientBrush>

        <!-- 日志条目 DataTemplate -->
        <DataTemplate x:Key="LogItemTemplate">
            <Border Margin="0,4"
                    Padding="0"
                    MinHeight="82"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6"
                                      ShadowDepth="1"
                                      Direction="270"
                                      Opacity="0.08"
                                      Color="#000000" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="8" />
                        <Setter Property="Background"
                                Value="{StaticResource InfoCardBg}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="WARN">
                                <Setter Property="Background"
                                        Value="{StaticResource WarnCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="ERROR">
                                <Setter Property="Background"
                                        Value="{StaticResource ErrorCardBg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NormalizedLevel}"
                                         Value="FATAL">
                                <Setter Property="Background"
                                        Value="{StaticResource FatalCardBg}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧 4px 实色竖线 -->
                    <Border Grid.Column="0"
                            CornerRadius="8,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource DarkSuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="WARN">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkWarningBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="ERROR">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkDangerBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="FATAL">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkDangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- 中间：时间戳 + 消息 -->
                    <StackPanel Grid.Column="1"
                                Margin="12,10,8,10"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,13" />
                        <TextBlock Text="{Binding Message}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   TextTrimming="None" />
                    </StackPanel>

                    <!-- 右侧 Badge：实色背景 + 白色文字 -->
                    <Border Grid.Column="2"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            CornerRadius="4"
                            Padding="0,3"
                            MinWidth="52">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="WARN">
                                        <Setter Property="Background"
                                                Value="{DynamicResource WarningBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="ERROR">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DangerBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NormalizedLevel}"
                                                 Value="FATAL">
                                        <Setter Property="Background"
                                                Value="{DynamicResource DarkWarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding NormalizedLevel}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                    </Border>

                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="4"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="清除日志"
                          Command="{Binding ClearLogsCommand}" />
            </ContextMenu>
        </Border.ContextMenu>
        <DockPanel Background="Transparent">

        <!-- 标题栏 -->
        <Grid DockPanel.Dock="Top"
              Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧渐变装饰条 -->
            <Border Grid.Column="0"
                    Width="4"
                    Height="18"
                    CornerRadius="2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">
                        <GradientStop Color="#06B6D4"
                                      Offset="0" />
                        <GradientStop Color="#3B82F6"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <TextBlock Grid.Column="1"
                       Text="实时日志记录模块"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TitleBrush}" />

            <!-- 右侧日志计数 Badge -->
            <Border Grid.Column="2"
                    CornerRadius="10"
                    Padding="8,3"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource LightPrimaryColor}" />
                </Border.Background>
                <Border BorderBrush="{DynamicResource PrimaryBrush}"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="0">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="{Binding Logs.Count, Mode=OneWay}" /><Run Text=" 条" />
                    </TextBlock>
                </Border>
            </Border>
        </Grid>
        <TextBlock DockPanel.Dock="Top"
                   Text="展示最新日志级别、时间与消息内容。"
                   Margin="16,0,16,8"
                   FontSize="12"
                   LineHeight="18"
                   Foreground="{DynamicResource SecondaryTextBrush}" />

        <!-- 分割线 -->
        <Border DockPanel.Dock="Top"
                Height="1"
                Margin="16,0,16,8"
                Background="{DynamicResource BorderBrush}"
                Opacity="0.35" />

        <!-- 列表区 -->
        <Grid>
            <!-- 空状态 -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding Logs.Count,
                            Converter={StaticResource CountToVisibilityConverter}}">
                <hc:TransitioningContentControl HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                    <Viewbox Margin="0"
                             Width="112"
                             Height="112">
                        <hc:AnimationPath VerticalAlignment="Center"
                                          Duration="0:0:6"
                                          Stretch="Uniform"
                                          Width="1024"
                                          Height="1024"
                                          StrokeThickness="20"
                                          Opacity="0.4"
                                          Stroke="{DynamicResource PrimaryBrush}"
                                          Data="{StaticResource GithubGeometry}" />
                    </Viewbox>
                </hc:TransitioningContentControl>
                <TextBlock Text="等待日志数据…"
                           Margin="0,8,0,0"
                           FontSize="12"
                               Opacity="0.5"
                               Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- 日志列表 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,0,16,12">
                <ItemsControl ItemsSource="{Binding Logs}"
                              ItemTemplate="{StaticResource LogItemTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin"
                                    Value="0,0,0,1" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        </DockPanel>
    </Border>
</UserControl>
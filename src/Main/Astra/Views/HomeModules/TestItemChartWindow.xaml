<Window x:Class="Astra.Views.HomeModules.TestItemChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scottplot="http://schemas.scottplot.net/2008/xaml/presentation"
        xmlns:home="clr-namespace:Astra.Views.HomeModules"
        Title="{Binding Name, StringFormat=测试项图表 - {0}}"
        Width="900"
        Height="600"
        MinWidth="700"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <!-- 系列显隐：整行悬停 -->
        <Style x:Key="SeriesVisibilityRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- 系列显隐：圆角勾选框 -->
        <Style x:Key="SeriesVisibilityCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Outer"
                                Width="18"
                                Height="18"
                                CornerRadius="5"
                                BorderThickness="1.5"
                                SnapsToDevicePixels="True"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource RegionBrush}">
                            <Path x:Name="Mark"
                                  Margin="3,3.5,3,2.5"
                                  Data="M 1 4 L 4 7 L 9 1"
                                  Stroke="{DynamicResource PrimaryBrush}"
                                  StrokeThickness="1.65"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Outer" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel x:Name="ToolbarPanel" Grid.Row="0" Margin="0,0,0,10" LastChildFill="True" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock Text="显示模式" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                <ComboBox x:Name="LayoutModeCombo"
                          Width="140"
                          SelectionChanged="OnLayoutModeChanged">
                    <ComboBoxItem Content="单图叠加" />
                    <ComboBoxItem Content="多子图" />
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="Auto" />
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftPanelBorder" Grid.Column="0"
                    Width="248"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource RegionBrush}"
                    Padding="12,12,10,10"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="系列显隐"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="2,0,0,6" />
                    <Border Height="2"
                            CornerRadius="1"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource PrimaryBrush}"
                            Opacity="0.35" />
                    <ItemsControl x:Name="SeriesVisibilityItemsControl"
                                  PreviewMouseLeftButtonDown="OnSeriesVisibilityItemsPreviewMouseLeft"
                                  ItemsSource="{Binding SeriesVisibilityRows, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type home:SeriesVisibilityRowModel}">
                                <Border Style="{StaticResource SeriesVisibilityRowStyle}">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="11"
                                                Height="11"
                                                CornerRadius="3"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                SnapsToDevicePixels="True"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                Background="{Binding SwatchBrush}"
                                                ToolTip="{Binding Name}" />
                                        <CheckBox Grid.Column="1"
                                                  Style="{StaticResource SeriesVisibilityCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   ToolTip="{Binding Name}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border x:Name="SplitterBorder" Grid.Column="1" Width="12" Visibility="Collapsed" />

            <Border Grid.Column="2"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource RegionBrush}">
                <Grid>
                    <scottplot:WpfPlot x:Name="ItemPlot" Margin="14" />
                    <ScrollViewer x:Name="SubPlotScrollViewer" Margin="14" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <!-- 多子图：一列多行纵向排列 -->
                        <UniformGrid x:Name="SubPlotHost" Columns="1" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

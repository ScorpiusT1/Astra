<UserControl x:Class="Astra.Views.HomeModules.IOMonitorModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:homemodules="clr-namespace:Astra.ViewModels.HomeModules" d:DataContext="{d:DesignInstance Type=homemodules:IOMonitorModuleViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="IOCardTemplate">
            <Border Margin="2,2,2,3"
                    Padding="10,9"
                    CornerRadius="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8"
                                      ShadowDepth="1"
                                      Opacity="0.12"
                                      Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Name}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0" />

                    <Ellipse Grid.Column="1"
                             x:Name="StatusDot"
                             Width="9"
                             Height="9"
                             VerticalAlignment="Center"
                             Fill="{DynamicResource SecondaryBorderBrush}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SecondaryBorderBrush}" />
                                <Setter Property="Opacity" Value="0.6" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOn}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                        <Setter Property="Opacity" Value="1" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="BreathStoryboard">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1"
                                                                     To="0.35"
                                                                     Duration="0:0:0.9" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="BreathStoryboard" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,10,0,0"
                            Padding="2,6"
                            CornerRadius="7"
                            >
                        <TextBlock Text="{Binding Value}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource DarkPrimaryBrush}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="16"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <Border Background="{DynamicResource LightInfoBrush}"
                    CornerRadius="6"
                    Padding="8,4">
                <TextBlock Text="IO监控模块"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleBrush}" />
            </Border>
            <ScrollViewer Margin="0,10,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Points}"
                              ItemTemplate="{StaticResource IOCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>

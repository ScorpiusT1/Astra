<UserControl x:Class="Astra.Views.HomeModules.IOMonitorModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Astra.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="400">

    <UserControl.Resources>
        <converters:IoValueDisplayConverter x:Key="IoValueDisplayConverter" />
    </UserControl.Resources>

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Margin="6"
            Padding="12">
        <!-- 列表区：最多可见 4 个（2 列×2 行）；超过则纵向滚动；少于 4 个时整块高度随内容收缩（ScrollViewer 在内容低于 MaxHeight 时不会撑满）。 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       Margin="0,0,0,10">
                <Border Width="4"
                        CornerRadius="2"
                        Margin="0,0,8,0"
                        Background="{StaticResource HomeModuleTitleInfoToPrimaryBrush}" />

                <TextBlock Text="IO 监控模块"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TitleBrush}" />

                <Border DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource IoMonitorHeaderCountPillStyle}">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding MonitorPointCount, StringFormat={}{0} 个点位}" />
                </Border>
            </DockPanel>
            <TextBlock Grid.Row="1"
                       Text="在「IO配置」中为点位勾选「首页监控」后，此处仅显示这些点位并轮询PLC实时值。"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       FontSize="12"
                       LineHeight="18"
                       Foreground="{DynamicResource SecondaryTextBrush}" />

            <Border Grid.Row="2"
                    ClipToBounds="True">
                <!-- MaxHeight = 2 行卡片：IoMonitorPointCardStyle MinHeight 72 + Margin 3×2，每行 78px -->
                <ScrollViewer MaxHeight="156"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Stretch">
                    <ItemsControl ItemsSource="{Binding Points}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 列宽约一半内容区（含 Margin 3 后两列≈满宽），WrapPanel 才能正确换行并累加总高度 -->
                                <Border Width="166"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource IoMonitorPointCardStyle}">
                                    <Grid>
                                        <Border Style="{StaticResource IoMonitorLeftStripeStyle}" />

                                        <StackPanel Margin="10,5,6,5"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding Address}"
                                                       FontSize="10"
                                                       LineHeight="14"
                                                       Margin="0,1,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Address}"
                                                                         Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Value, Converter={StaticResource IoValueDisplayConverter}}"
                                                       Style="{StaticResource IoMonitorValueTextStyle}" />
                                        </StackPanel>

                                        <Ellipse Style="{StaticResource IoMonitorStatusDotStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </Grid>
    </Border>

</UserControl>

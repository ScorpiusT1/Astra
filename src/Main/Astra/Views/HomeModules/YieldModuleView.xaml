<UserControl x:Class="Astra.Views.HomeModules.YieldModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="16"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <Border Background="{DynamicResource LightPrimaryBrush}"
                    CornerRadius="6"
                    Padding="8,4">
                <TextBlock Text="良率显示模块"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleBrush}" />
            </Border>
            <UniformGrid Columns="4"
                         Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="总测试数" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    <TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource DarkPrimaryBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="通过数" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    <TextBlock Text="{Binding PassCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="失败数" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    <TextBlock Text="{Binding FailCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="当前良率" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    <TextBlock Text="{Binding YieldPercent, StringFormat={}{0:F2}%}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" />
                </StackPanel>
            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>

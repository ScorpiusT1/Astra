<UserControl x:Class="Astra.Views.HomeModules.YieldModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Background="{DynamicResource RegionBrush}"
            CornerRadius="12"
            Padding="16"
            Margin="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="清除当日良率"
                          Command="{Binding ClearYieldCommand}" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="4"
                        CornerRadius="2"
                        Margin="0,0,10,0"
                        Background="{StaticResource HomeModuleTitleInfoToPrimaryBrush}" />

                <TextBlock Grid.Column="1"
                           Text="良率显示模块"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TitleBrush}" />

                <Border Grid.Column="2"
                        CornerRadius="10"
                        Padding="8,3"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SuccessBrush}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Color="{DynamicResource LightSuccessColor}"
                                          Offset="0" />
                            <GradientStop Color="{DynamicResource LightInfoColor}"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{DynamicResource SuccessBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0" />
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="良率 {0:F2}%">
                                    <Binding Path="YieldPercent" />
                                </MultiBinding>
                            </TextBlock.Text>
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource SuccessColor}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource InfoColor}"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
            <TextBlock Text="良率为核心指标，辅助展示总数/通过/失败统计。"
                       Margin="0,10,0,0"
                       FontSize="12"
                       LineHeight="18"
                       Foreground="{DynamicResource SecondaryTextBrush}" />

            <UniformGrid Columns="2"
                         Margin="0,10,0,0">

                <Border Style="{StaticResource YieldStatCardTotalStyle}">
                    <Grid>
                        <Border Style="{StaticResource YieldStatCardPrimaryStripeStyle}" />
                        <StackPanel Style="{StaticResource YieldStatCardContentPanelStyle}">
                            <TextBlock Text="总测试数"
                                       Style="{StaticResource YieldStatCardMetricLabelStyle}" />
                            <TextBlock Text="{Binding TotalCount}"
                                       Style="{StaticResource YieldStatCardMetricValuePrimaryStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource YieldStatCardPassStyle}">
                    <Grid>
                        <Border Style="{StaticResource YieldStatCardSuccessStripeStyle}" />
                        <StackPanel Style="{StaticResource YieldStatCardContentPanelStyle}">
                            <TextBlock Text="通过数"
                                       Style="{StaticResource YieldStatCardMetricLabelStyle}" />
                            <TextBlock Text="{Binding PassCount}"
                                       Style="{StaticResource YieldStatCardMetricValueSuccessStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource YieldStatCardFailStyle}">
                    <Grid>
                        <Border Style="{StaticResource YieldStatCardDangerStripeStyle}" />
                        <StackPanel Style="{StaticResource YieldStatCardContentPanelStyle}">
                            <TextBlock Text="失败数"
                                       Style="{StaticResource YieldStatCardMetricLabelStyle}" />
                            <TextBlock Text="{Binding FailCount}"
                                       Style="{StaticResource YieldStatCardMetricValueDangerStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource YieldStatCardCurrentYieldStyle}">
                    <Grid>
                        <Border Style="{StaticResource YieldStatCardWarningStripeBorderStyle}" />
                        <StackPanel Style="{StaticResource YieldStatCardContentPanelStyle}">
                            <TextBlock Text="当前良率"
                                       Style="{StaticResource YieldStatCardMetricLabelStyle}" />
                            <TextBlock Text="{Binding YieldPercent,Mode=OneWay,UpdateSourceTrigger=PropertyChanged,StringFormat={}{0:F2}%}"
                                       Style="{StaticResource YieldStatCardMetricValueWarningStyle}" />
                            <ProgressBar Style="{StaticResource YieldModuleProgressBarStyle}"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding YieldPercent,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>

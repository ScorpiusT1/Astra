<UserControl x:Class="Astra.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Astra.Views"
             xmlns:localConverters="clr-namespace:Astra.Converters"
             xmlns:viewmodels="clr-namespace:Astra.ViewModels"
             xmlns:models="clr-namespace:Astra.Models"
             xmlns:behaviors="clr-namespace:Astra.Behaviors"
             xmlns:converters="clr-namespace:Astra.UI.Converters;assembly=Astra.UI"
             d:DataContext="{d:DesignInstance Type=viewmodels:ConfigViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource SurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <localConverters:TextTruncateConverter x:Key="TextTruncateConverter" DefaultMaxLength="30" />
        <localConverters:TreeNodeContextMenuVisibilityConverter x:Key="TreeNodeContextMenuVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <!-- 主内容区域 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧树状导航 -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题行 -->
                    <TextBlock Grid.Row="0"
                               Text="配置树"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Margin="16,16,16,12"
                               VerticalAlignment="Center" />

                    <!-- 树状列表（可滚动） -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TreeView x:Name="ConfigTreeView"
                                  ItemsSource="{Binding TreeNodes}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="8"
                                  AllowDrop="True">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem"
                                       BasedOn="{StaticResource TreeNodeStyle}">
                                    <Setter Property="IsExpanded"
                                            Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected"
                                            Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="AllowDrop"
                                            Value="True" />
                                    <Setter Property="behaviors:TreeViewItemBehaviors.SelectedCommand"
                                            Value="{Binding DataContext.NodeSelectedCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <Setter Property="behaviors:TreeViewItemBehaviors.SelectedCommandParameter"
                                            Value="{Binding}" />
                                    <Setter Property="behaviors:TreeViewItemBehaviors.DragDropCommand"
                                            Value="{Binding DataContext.DragDropNodeCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <!-- 根节点菜单：导入/导出 -->
                                                <MenuItem Header="📥 导入配置"
                                                          Command="{Binding ImportConfigurationsCommand}"
                                                          CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext}"
                                                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext, Converter={StaticResource TreeNodeContextMenuVisibilityConverter}, ConverterParameter=ImportExport}" />
                                                <MenuItem Header="📤 导出配置"
                                                          Command="{Binding ExportConfigurationsCommand}"
                                                          CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext}"
                                                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext, Converter={StaticResource TreeNodeContextMenuVisibilityConverter}, ConverterParameter=ImportExport}" />
                                                <Separator Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext, Converter={StaticResource TreeNodeContextMenuVisibilityConverter}, ConverterParameter=ImportExport}" />
                                                <!-- 子节点菜单：保存 -->
                                                <MenuItem Header="💾 保存此配置"
                                                          Command="{Binding SaveSingleConfigurationCommand}"
                                                          CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext}"
                                                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext, Converter={StaticResource TreeNodeContextMenuVisibilityConverter}, ConverterParameter=Save}" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                </Style>
                            </TreeView.ItemContainerStyle>

                            <TreeView.Resources>
                                <!-- 第一层：设备配置/传感器配置 -->
                                <HierarchicalDataTemplate DataType="{x:Type models:TreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="0" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Grid.Column="0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Margin="6,0,0,0"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Header, Converter={StaticResource TextTruncateConverter}, ConverterParameter=30}"
                                                       ToolTip="{Binding Header}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="180">
                                                <!-- 设置 ToolTip 立即显示，无延迟 -->
                                                <ToolTipService.InitialShowDelay>0</ToolTipService.InitialShowDelay>
                                                <ToolTipService.ShowDuration>5000</ToolTipService.ShowDuration>
                                                <ToolTipService.BetweenShowDelay>0</ToolTipService.BetweenShowDelay>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource AddButton}"
                                                Margin="8,0,4,0"
                                                Visibility="{Binding ShowAddButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Command="{Binding DataContext.AddNodeCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding}" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource DeleteButton}"
                                                Margin="0,0,0,0"
                                                Visibility="{Binding ShowDeleteButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Command="{Binding DataContext.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="删除" />
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </ScrollViewer>

                    <!-- 保存按钮 -->
                    <Border Grid.Row="2"
                            Background="Transparent"
                            Padding="16,12,16,16"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Button Content="💾 保存所有配置"
                                Padding="16,8"
                                MinWidth="120"
                                Height="36"
                                FontSize="13"
                                Command="{Binding SaveAllConfigurationsCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                ToolTip="保存树中所有配置" />
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧配置面板 -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0"
                    Margin="20"
                    CornerRadius="8">
                <ContentControl x:Name="ConfigContentRegion"
                                Margin="0"
                                 />
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Astra.Views.DataQueryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Astra.ViewModels"
             xmlns:converters="clr-namespace:Astra.Converters"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             d:DataContext="{d:DesignInstance Type=viewmodels:DataQueryViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="768"
             d:DesignWidth="1280"
             Background="{DynamicResource BackgroundBrush}"
             Loaded="DataQueryView_OnLoaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Themes/Converters.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/Controls/CommonStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/HomeModules/HomeModuleStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/Controls/InputStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/Controls/Buttons.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/Controls/DataGrids.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Astra.UI;component/Styles/Pages/DataQueryViewStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:FileByteSizeConverter x:Key="FileByteSizeConverter" />
            <converters:UtcToLocalDateTimeConverter x:Key="UtcToLocalDateTimeConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20,16,20,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="160" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <Border Grid.Row="0"
                Style="{StaticResource DataQueryFilterCardStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource DataQueryTitleAccentStripeStyle}"
                        VerticalAlignment="Stretch" />
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{DynamicResource LightPrimaryBrush}"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <fa:IconBlock Icon="Search"
                                          FontSize="20"
                                          Foreground="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="数据查询"
                                       Style="{StaticResource DataQueryPageTitleStyle}"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Text="按 SN、日期与数据类型检索「测试数据」目录下的原始数据、音频、算法数据、报告与运行日志（含未归档到测试数据目录时的本地 RunLogs）。双击行可用默认程序打开文件；右键可打开所在文件夹。"
                                       Style="{StaticResource DataQuerySubtitleStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 筛选条件 -->
        <Border Grid.Row="1"
                Style="{StaticResource DataQueryFilterCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="168" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="168" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="SN"
                           Style="{StaticResource DataQueryFieldLabelStyle}"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SnFilter, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         MinHeight="40"
                         Margin="0,0,18,0"
                         VerticalAlignment="Center"
                         ToolTip="匹配 SN 文件夹名（子串，不区分大小写）" />
                <TextBlock Grid.Column="2"
                           Text="开始日期"
                           Style="{StaticResource DataQueryFieldLabelStyle}"
                           VerticalAlignment="Center" />

                <hc:DatePicker Grid.Column="3"
                               Margin="0,0,18,0"
                               SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="13"
                               hc:BorderElement.CornerRadius="10"
                               hc:BorderThickness="1.5"
                               Height="40"
                               VerticalAlignment="Center"
                               hc:InfoElement.Placeholder="请选择日期" />

                <TextBlock Grid.Column="4"
                           Text="结束日期"
                           Style="{StaticResource DataQueryFieldLabelStyle}"
                           VerticalAlignment="Center" />

                <hc:DatePicker Grid.Column="5"
                               Margin="0,0,18,0"
                               SelectedDate="{Binding ToDate, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="13"
                               hc:BorderThickness="1.5"
                               hc:BorderElement.CornerRadius="10"
                               Height="40"
                               VerticalAlignment="Center"
                               hc:InfoElement.Placeholder="请选择日期" />

                <TextBlock Grid.Column="6"
                           Text="数据类型"
                           Style="{StaticResource DataQueryFieldLabelStyle}"
                           VerticalAlignment="Center" />
                <ComboBox Grid.Column="7"
                          Height="40"
                          Style="{StaticResource ModernComboBoxStyle}"
                          SelectedIndex="{Binding DataTypeFilterIndex, Mode=TwoWay}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          ToolTip="原始数据：合并 Raw TDMS；音频数据：按通道导出的 WAV；算法数据：算法节点导出的 TDMS；报告：HTML/PDF、run_record、图表 PNG；运行日志：各次运行/批次的 .log（测试数据目录 + 本地 RunLogs）">
                    <ComboBoxItem Content="全部"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                    <ComboBoxItem Content="原始数据"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                    <ComboBoxItem Content="音频数据"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                    <ComboBoxItem Content="算法数据"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                    <ComboBoxItem Content="报告"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                    <ComboBoxItem Content="运行日志"
                                  Style="{StaticResource ModernComboBoxItemStyle}" />
                </ComboBox>
                <Button Grid.Column="8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="查 询"
                        Command="{Binding SearchCommand}"
                        VerticalAlignment="Center"
                        Padding="22,8"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>
        </Border>

        <!-- 结果表格 -->
        <Border Grid.Row="2"
                Style="{StaticResource DataQueryGridHostStyle}">
            <DataGrid x:Name="ResultGrid"
                      Margin="12,12,12,4"
                      FontSize="14"
                      RowHeight="52"
                      ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      MouseDoubleClick="ResultGrid_OnMouseDoubleClick"
                      PreviewMouseRightButtonDown="ResultGrid_OnPreviewMouseRightButtonDown"
                      ColumnHeaderStyle="{StaticResource ResizableModernDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource EnhancedModernDataGridRowStyle}"
                      AlternationCount="2"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="打开所在文件夹"
                                  Command="{Binding OpenRowContainingFolderCommand}"
                                  ToolTip="打开当前行文件所在的文件夹" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号"
                                        Binding="{Binding TableSequence}"
                                        Width="56"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="类型"
                                        Binding="{Binding CategoryDisplayName}"
                                        Width="108"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="日期"
                                        Binding="{Binding DateFolder}"
                                        Width="108"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="SN"
                                        Binding="{Binding SnFolder}"
                                        Width="130"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="运行"
                                        Binding="{Binding RunFolder}"
                                        Width="72"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="文件名"
                                        Binding="{Binding FileName}"
                                        Width="*"
                                        MinWidth="160"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="大小"
                                        Width="96"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Binding>
                            <Binding Path="LengthBytes"
                                     Converter="{StaticResource FileByteSizeConverter}" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="修改时间"
                                        Width="158"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Binding>
                            <Binding Path="LastWriteTimeUtc"
                                     Converter="{StaticResource UtcToLocalDateTimeConverter}" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="路径"
                                        Binding="{Binding FullPath}"
                                        Width="2*"
                                        MinWidth="220"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 底栏：状态与分页同一行；分页在整行宽度内水平居中 -->
        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="4,10"
                Background="Transparent">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="每页"
                               Style="{StaticResource DataQueryFieldLabelStyle}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <ComboBox Width="88"
                              Margin="0,0,20,0"
                              Height="40"
                              VerticalAlignment="Center"
                              Style="{StaticResource ModernComboBoxStyle}"
                              ItemsSource="{Binding PageSizeOptions}"
                              SelectedItem="{Binding PageSize, Mode=TwoWay}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem"
                                   BasedOn="{StaticResource ModernComboBoxItemStyle}" />
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <Button Content="上一页"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToPreviousPageCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                    <Button Content="下一页"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToNextPageCommand}"
                            Padding="14,8"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding PagingLabel}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="Astra.Engine.Views.TriggerConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Astra.Engine.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Thickness x:Key="PagePadding">20</Thickness>
        <Thickness x:Key="CardSpacing">0,14,0,0</Thickness>
        <Thickness x:Key="FieldSpacing">0,8,0,0</Thickness>
        <Thickness x:Key="ColumnGap">16,0,0,0</Thickness>

        <Style x:Key="PageTitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="20" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,2" />
        </Style>
        <Style x:Key="PageSubtitleStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Opacity"
                    Value="0.78" />
            <Setter Property="Foreground"
                    Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style x:Key="ModernFormTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource DefaultModernTextBoxStyle}">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="MinWidth"
                    Value="220" />
            <Setter Property="Margin"
                    Value="{StaticResource FieldSpacing}" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
        </Style>

        <Style x:Key="ModernFormComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource ModernComboBoxStyle}">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="MinWidth"
                    Value="220" />
            <Setter Property="Margin"
                    Value="{StaticResource FieldSpacing}" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 页面标题区 -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,6">
            <TextBlock Text="触发器配置"
                       Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="配置触发来源、工作模式、引擎类型及防重复策略。"
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <!-- 基本信息 -->
        <Border Grid.Row="1"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="基本信息"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical">
                        <TextBlock Text="配置名称"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.ConfigName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="显示名称"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 工作模式 -->
        <Border Grid.Row="2"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="工作模式"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical">
                        <TextBlock Text="触发来源"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox Style="{StaticResource ModernFormComboBoxStyle}"
                                  ItemsSource="{Binding TriggerSources}"
                                  SelectedItem="{Binding Config.Source, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="工作模式"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox Style="{StaticResource ModernFormComboBoxStyle}"
                                  ItemsSource="{Binding WorkModes}"
                                  SelectedItem="{Binding Config.WorkMode, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              Margin="18,22,0,0"
                              Content="启用"
                              VerticalAlignment="Center"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              IsChecked="{Binding Config.IsEnabled, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
        </Border>

        <!-- 引擎类型 / PLC 配置 -->
        <Border Grid.Row="3"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="引擎类型"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <!-- 引擎类型配置 -->
                <StackPanel Grid.Row="1"
                            Orientation="Vertical">
                    <TextBlock Text="Trigger 引擎类型（完整类型名）"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                             Text="{Binding Config.EngineTypeName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- PLC 触发配置，仅在触发来源为 PLCMonitor 时显示 -->
                <StackPanel Grid.Row="2"
                            Orientation="Vertical"
                            Margin="0,14,0,0"
                            Visibility="{Binding IsPlcSource, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="PLC 触发配置"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical">
                            <TextBlock Text="PLC 标识（名称 / IP）"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                     Text="{Binding Config.PlcIdentifier, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    Margin="{StaticResource ColumnGap}">
                            <TextBlock Text="监控 IO 点位地址"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                     Text="{Binding Config.PlcMonitorAddress, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Vertical"
                                Margin="0,8,0,0">
                        <TextBlock Text="SN 读取地址（可选）"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 Text="{Binding Config.PlcSnAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 防重复设置 -->
        <Border Grid.Row="4"
                Margin="{StaticResource CardSpacing}"
                Style="{StaticResource ModernCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="防重复设置"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Content="启用防重复"
                              VerticalAlignment="Center"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              IsChecked="{Binding Config.AntiRepeat.Enabled, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Margin="18,0,0,0">
                        <TextBlock Text="同 SN 最小间隔 (ms)"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 MinWidth="140"
                                 Text="{Binding Config.AntiRepeat.MinIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                Margin="{StaticResource ColumnGap}">
                        <TextBlock Text="全局最小间隔 (ms)"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Style="{StaticResource ModernFormTextBoxStyle}"
                                 MinWidth="140"
                                 Text="{Binding Config.AntiRepeat.GlobalMinIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
